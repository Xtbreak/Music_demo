// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// 管理员表
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // bcrypt 加密存储
  name      String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// 歌曲分类表
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  songs Song[]

  @@map("categories")
}

// 乐器类型表
model Instrument {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sheets Sheet[]

  @@map("instruments")
}

// 歌曲表
model Song {
  id           String   @id @default(cuid())
  title        String
  titlePinyin  String?  // 拼音，用于搜索
  lyrics       String   // 歌词
  lyricsPlain  String?  // 纯文本歌词（无标签），用于搜索
  author       String?  // 作者/作曲者
  description  String?  // 歌曲描述
  tags         String?  // 标签，逗号分隔
  viewCount    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  sheets     Sheet[]

  @@index([title])
  @@index([categoryId])
  @@map("songs")
}

// 乐谱/歌单表
model Sheet {
  id            String   @id @default(cuid())
  name          String?  // 乐谱名称（可选，默认用乐器名）
  content       String   // 乐谱内容（和弦、简谱等）
  fileUrl       String?  // 乐谱文件链接（如 PDF）
  keySignature   String? // 调性（如 C, D, G）
  capo          Int?     // 变调夹位置（吉他用）
  tempo         Int?     // 速度（BPM）
  timeSignature String?  // 拍号（如 4/4）
  notes         String?  // 备注
  sortOrder     Int      @default(0) // 排序
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  songId       String
  song         Song       @relation(fields: [songId], references: [id], onDelete: Cascade)
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])

  @@unique([songId, instrumentId]) // 一首歌的同一乐器只能有一个乐谱
  @@index([songId])
  @@index([instrumentId])
  @@map("sheets")
}